# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=docextract

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# JWT 安全密钥（生产环境必须修改为随机字符串）
SECRET_KEY=change-this-to-a-very-long-random-secret-key-in-production

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# 对象存储 (MinIO)
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_SECURE=false

# LLM 配置
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o

# DeepSeek (可选)
# DEEPSEEK_API_KEY=your-deepseek-api-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 自定义 OpenAI 兼容提供商（任意第三方兼容端点）
# CUSTOM_API_KEY=your-custom-api-key
# CUSTOM_BASE_URL=http://your-llm-endpoint/v1
# CUSTOM_DEFAULT_MODEL=custom-model

# Default provider: openai | deepseek | ollama | custom

# 调试模式（生产环境设为 false）
DEBUG=false
LOG_LEVEL=INFO
