# 数据库
DB_HOST=localhost
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=admin
DB_NAME=docextract

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=admin

# JWT（请替换为随机长字符串）
SECRET_KEY=admin
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DEFAULT_ADMIN_PASSWORD=admin123

# MinIO 对象存储
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=12345678
STORAGE_SECRET_KEY=12345678
STORAGE_BUCKET_DOCUMENTS=documents
STORAGE_BUCKET_RESULTS=results
STORAGE_SECURE=false

# LLM 配置（至少填写一个）
OPENAI_API_KEY=sk-your-openai-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o

DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_DEFAULT_MODEL=deepseek-chat

# 自定义 OpenAI 兼容提供商（任意第三方兼容端点）
CUSTOM_API_KEY=sk-l6XyohHodLtoG8QOaac3EQ
CUSTOM_BASE_URL=https://llmapi.paratera.com
CUSTOM_DEFAULT_MODEL=MiniMax-Text-01

# Default provider: openai | deepseek | ollama | custom
DEFAULT_LLM_PROVIDER=custom
DEFAULT_LLM_MODEL=MiniMax-Text-01

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# 应用
DEBUG=false
MAX_UPLOAD_SIZE=104857600
RATE_LIMIT_PER_MINUTE=60
